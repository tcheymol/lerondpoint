{% set assignedTo = track.assignedTo %}
{% set isAssignedToMe = assignedTo and assignedTo.id == app.user.id %}

<form method="post" action="{{ path('moderate_track_assign', {id: track.id}) }}" class="d-flex align-items-center gap-2 mt-2">
    <input type="hidden" name="filter" value="{{ filter|default('all') }}">

    {% if is_granted('ROLE_ADMIN') %}
        <select name="assigned_to_id" class="form-select form-select-sm" style="max-width: 180px;" onchange="this.form.submit()">
            <option value="">{{ 'ModerationUnassign'|trans }}</option>
            {% for moderator in moderators %}
                <option value="{{ moderator.id }}" {{ assignedTo and assignedTo.id == moderator.id ? 'selected' : '' }}>
                    {{ moderator.username ?? moderator.email }}
                </option>
            {% endfor %}
        </select>
    {% else %}
        {% if isAssignedToMe %}
            <button type="submit" name="assigned_to_id" value="" class="btn btn-sm btn-outline-secondary">
                {{ 'ModerationUnassign'|trans }}
            </button>
        {% else %}
            <button type="submit" name="assigned_to_id" value="{{ app.user.id }}" class="btn btn-sm btn-outline-primary">
                {{ 'ModerationAssignMe'|trans }}
            </button>
        {% endif %}
    {% endif %}

    {% if assignedTo %}
        {% if isAssignedToMe %}
            <span class="badge bg-primary border border-dark text-white">{{ assignedTo.username ?? assignedTo.email }}</span>
        {% else %}
            <span class="badge bg-warning border border-dark text-dark">{{ assignedTo.username ?? assignedTo.email }}</span>
        {% endif %}
    {% else %}
        <span class="badge bg-secondary border border-dark text-white">{{ 'ModerationFilterUnassigned'|trans }}</span>
    {% endif %}
</form>
