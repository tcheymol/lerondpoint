<div class="card text-bg-white mt-3 rounded-0 shadow">
    <div class="card-header rounded-0 bg-secondary border-bottom-0 d-flex align-items-center">
        <span class="plaine">{{ collective.name }} </span>
        <span class="ms-auto">
            {% if is_granted('EDIT', collective) %}
                <a class="btn btn-link link-dark" href="{{ path('collective_complete', {id: collective.id, step: 1}) }}">{{ 'UpdateInformation'|trans }}</a>
                <a class="btn btn-link link-dark" href="{{ path('collective_complete', {id: collective.id, step: 2}) }}">{{ 'AddToMap'|trans }}</a>
            {% endif %}
        </span>
    </div>
    <div class="card-body border-0">
        <div class="row d-flex justify-content-between">
            <div class="col">
                <span> {{ collective.shortDescription }} </span>
            </div>
            <div class="col align-items-end d-flex">
                {% if(collective.logoPath or collective.iconPath) and collective.iconPath != 'icone' %}
                    <img style="width: 50px" class="ms-auto" src="{{ collective.logoPath ?? collective.iconPath }}" alt="{{ 'Collective'|trans }}"/>
                {% elseif is_granted('EDIT', collective) %}
                    <a class="btn btn-outline-secondary btn-sm ms-auto" href="{{ path('collective_complete', {id: collective.id, step: 1}) }}">
                        <i class="bi bi-image"></i> {{ 'AddIcon'|trans }}
                    </a>
                {% else %}
                    <div class="ms-auto d-flex align-items-center justify-content-center bg-light border rounded" style="width: 50px; height: 50px;">
                        <i class="bi bi-image text-muted"></i>
                    </div>
                {% endif %}
            </div>
        </div>
        <div class="row d-flex justify-content-between mt-3">
            <div class="col">
                <a class="btn btn-link link-secondary" href="{{ path('track_list', { collectives: collective.id }) }}">{{ 'ViewCollectiveTracks'|trans }}</a>
            </div>
            <div class="col text-end">
                <a class="btn btn-link link-secondary" href="{{ path('collective_invite', { id: collective.id }) }}">{{ 'InviteUser'|trans }}</a>
            </div>
        </div>
    </div>
</div>
